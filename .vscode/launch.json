    "version": "0.2.0",
    "configurations": [
    
        {
            "type": "java",
            "name": "Current File",
            "request": "launch",
            "mainClass": "${file}"
        },
        {
            "type": "java",
            "name": "Run: Dev",
            "request": "launch",
            "mainClass": "cl.potion.api.ApiApplication",
            "projectName": "potion-api",
            "args": [
                "--spring.profiles.active=dev"
            ],
            "env": {
                "DB_USER":"postgress",
                "DB_PASSWORD":"postgress"
            }
        },
        {
            "type": "java",
            "name": "Run: Prod",
            "request": "launch",
            "mainClass": "cl.potion.api.ApiApplication",
            "projectName": "potion-api",
            "args": [
                "--spring.profiles.active=prod"
            ],
            "env": {
                "DB_USER":"postgress",
                "DB_PASSWORD":"postgress"
            }
        }
    ]
}